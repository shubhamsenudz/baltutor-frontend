# --- Vite dev server (read by vite.config.ts; not bundled into the app unless prefixed VITE_) ---
VITE_DEV_PORT=5173
# Backend base URL for the dev proxy (must match Spring server.port, default 8080)
VITE_DEV_API_TARGET=http://localhost:8080
# Set to 1 to bind 0.0.0.0 (LAN / device testing)
# VITE_DEV_HOST=1

# Vite production preview (npm run preview) — CORS on API allows 4173 by default
VITE_PREVIEW_PORT=4173

# --- Browser bundle: optional absolute API base (production static hosting) ---
# Leave empty to use relative /api (same origin as the web app, or Vite proxy in dev).
# VITE_API_BASE=https://api.yourdomain.com
